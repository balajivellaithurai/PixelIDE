# PixelIDE Environment Configuration Example

# Gemini API Key (Get your key from Google AI Studio)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Default AI Provider (gemini | openai | claude | groq | ollama)
VITE_AI_PROVIDER=gemini

# Default AI Model for Gemini (gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash)
VITE_AI_MODEL=gemini-1.5-flash

# Default AI Sampling Temperature (0.0 - 1.0)
VITE_AI_TEMPERATURE=0.7

# Default AI Request Timeout in Milliseconds
VITE_AI_TIMEOUT_MS=30000
